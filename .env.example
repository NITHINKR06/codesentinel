# CodeSentinel Environment Variables
# Copy this to .env and fill in your values

# GitHub personal access token (for PR creation)
GITHUB_TOKEN=ghp_your_token_here

# VirusTotal API key (optional — for dependency reputation)
VIRUSTOTAL_API_KEY=your_vt_key_here

# Ollama model (default: codellama:13b)
# Other options: llama3.2, qwen2.5-coder, deepseek-coder
OLLAMA_MODEL=codellama:13b

# Set to false to disable debug logging
DEBUG=false

# GROQ API key (for code search)
GROQ_API_KEY=your_groq_key_here

# GitHub token for commit attribution
GITHUB_TOKEN=ghp_xxxx   ← token from the CodeSentinel bot account